NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=medassist-v3
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: switch ma-web to the local Data Connect emulator.
NEXT_PUBLIC_USE_DATACONNECT_EMULATOR=false
NEXT_PUBLIC_DATACONNECT_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_DATACONNECT_EMULATOR_PORT=9399

# Optional: enable Gemini-backed features such as retinal screening and dashboard AI chat.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional: enable dashboard OCR via Google Document AI (server-only).
OCR_GOOGLE_PROJECT_ID=
OCR_GOOGLE_LOCATION=asia-southeast1
OCR_GOOGLE_PROCESSOR_ID=
OCR_GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# Recommended for Vercel: put full service account JSON as Base64 in one line.
OCR_GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative for Vercel: paste full JSON directly as a single secret.
# OCR_GOOGLE_SERVICE_ACCOUNT_JSON=

# Local-only file path option (do NOT use on Vercel).
# OCR_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Alternative auth vars (use this pair instead of JSON/Base64 if needed).
# OCR_GOOGLE_SERVICE_ACCOUNT_EMAIL=
# OCR_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional file size limit in MB for /api/ocr/document uploads.
OCR_MAX_FILE_SIZE_MB=12
